# Sao chép file này thành .env rồi điền giá trị. TUYỆT ĐỐI không chia sẻ .env.
# .env đã được .gitignore bỏ qua — không bao giờ commit key lên git.

# --- Chế độ ---
TRADE_MODE=testnet          # testnet | live   (khuyến nghị: testnet)
DRY_RUN=true                # true = KHÔNG gửi lệnh thật, chỉ mô phỏng & log

# --- API key ---
# Testnet: tạo tại https://testnet.binance.vision (key riêng, khác key thật)
# Live:    tạo tại Binance > API Management. CHỈ bật quyền Spot Trading.
#          TUYỆT ĐỐI KHÔNG bật quyền Withdraw. Nên bật IP whitelist.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Danh mục ---
USE_GAINERS=10             # top N gainer hiện tại (khớp backtest top_n=10)

# --- Vốn & rủi ro ---
MAX_CAPITAL=1000           # vốn TỐI ĐA bot được dùng dù ví có nhiều hơn (0 = dùng toàn ví)
RISK_PER_TRADE=0.02         # 2%/lệnh
TP_PCT=0.03                 # +3% (bị bỏ qua khi bật trailing)
MAX_SL_PCT=0.02             # -2%
MAX_OPEN_TRADES=3
DAILY_STOP=0.05             # ngưng lỗ 5%/ngày

# --- Cải tiến đã kiểm chứng (cấu hình tốt nhất từ backtest) ---
USE_TREND_FILTER=true       # chỉ vào khi giá > EMA
TREND_EMA=50
USE_TRAILING=true           # để lời chạy, bỏ chốt cứng TP
TRAIL_PCT=0.03
USE_STALL_EXIT=true         # cắt lệnh chết yểu sau N giờ
STALL_BARS=12
USE_GAIN_FILTER=true        # né coin đã tăng trong "vùng chết"
GAIN_AVOID_LO=0.05
GAIN_AVOID_HI=0.10

# --- V2 (bản thực chiến) ---
USE_MARKET_FILTER=true      # chỉ giao dịch khi BTC nằm trên EMA (lọc downtrend toàn thị trường)
MARKET_EMA=50               # BTC > EMA50 (nến ngày)
MARKET_SYMBOL=BTC/USDT
MAX_EQUITY_PER_TRADE=0.15   # trần vốn tối đa/lệnh = 15% (chống bẫy thanh khoản khi SL hẹp)
STALL_MIN_PROFIT=0.01       # cắt lệnh chết yểu nếu sau STALL_BARS chưa lời > 1%

# --- An toàn ---
HARD_STOP_ON_EXCHANGE=true  # đặt STOP-LOSS phía sàn làm phao cứu sinh
MAX_TOTAL_DRAWDOWN=0.20     # tự dừng bot nếu sụt >20% từ đỉnh
LOOP_SECONDS=300            # quét mỗi 5 phút
KILL_FILE=STOP              # tạo file tên này để dừng bot an toàn

# --- Cảnh báo Telegram (tuỳ chọn) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
