# Sao chép file này thành .env rồi điền giá trị. TUYỆT ĐỐI không chia sẻ .env.
# .env đã được .gitignore bỏ qua — không bao giờ commit key lên git.

# --- Chế độ ---
TRADE_MODE=testnet          # testnet | live   (khuyến nghị: testnet)
DRY_RUN=true                # true = KHÔNG gửi lệnh thật, chỉ mô phỏng & log

# --- API key ---
# Testnet: tạo tại https://testnet.binance.vision (key riêng, khác key thật)
# Live:    tạo tại Binance > API Management. CHỈ bật quyền Spot Trading.
#          TUYỆT ĐỐI KHÔNG bật quyền Withdraw. Nên bật IP whitelist.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Danh mục ---
SYMBOLS=SOL/USDT,AVAX/USDT,LINK/USDT
USE_GAINERS=0               # >0: bỏ qua SYMBOLS, tự lấy N top gainer đã lọc

# --- Vốn & rủi ro ---
INITIAL_CAPITAL=1000
RISK_PER_TRADE=0.02         # 2%/lệnh
TP_PCT=0.03                 # +3%
MAX_SL_PCT=0.02             # -2%
MAX_OPEN_TRADES=3
DAILY_STOP=0.05             # ngưng lỗ 5%/ngày

# --- An toàn ---
HARD_STOP_ON_EXCHANGE=true  # đặt STOP-LOSS phía sàn làm phao cứu sinh
MAX_TOTAL_DRAWDOWN=0.20     # tự dừng bot nếu sụt >20% từ đỉnh
LOOP_SECONDS=300            # quét mỗi 5 phút
KILL_FILE=STOP              # tạo file tên này để dừng bot an toàn

# --- Cảnh báo Telegram (tuỳ chọn) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
