# Sao chép thành .env rồi điền. KHÔNG commit .env, KHÔNG chia sẻ key.

# --- Chế độ ---
TRADE_MODE=testnet          # testnet | live
DRY_RUN=true                # true = mô phỏng, không gửi lệnh thật (khuyến nghị cho chiến lược top-gainer)

# --- API key (testnet: https://testnet.binance.vision) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Danh mục ---
USE_GAINERS=10              # top N gainer hiện tại toàn thị trường

# --- Vốn & rủi ro ---
MAX_CAPITAL=1000            # vốn TỐI ĐA bot dùng dù ví nhiều hơn (0 = toàn ví)
RISK_PER_TRADE=0.02
MAX_SL_PCT=0.02
MAX_OPEN_TRADES=3
DAILY_STOP=0.05

# --- Cải tiến đã kiểm chứng (cấu hình tốt nhất) ---
USE_TREND_FILTER=true
TREND_EMA=50
USE_TRAILING=true
TRAIL_PCT=0.03
USE_STALL_EXIT=true
STALL_BARS=12
USE_GAIN_FILTER=true
GAIN_AVOID_LO=0.05
GAIN_AVOID_HI=0.10

# --- An toàn ---
HARD_STOP_ON_EXCHANGE=true
MAX_TOTAL_DRAWDOWN=0.20
LOOP_SECONDS=300
KILL_FILE=STOP

# --- Telegram (tuỳ chọn) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
